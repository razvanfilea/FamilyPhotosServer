{
  "name": "familyphotos",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i templates/input.css -o assets/css/main.css --watch",
    "prod": "npx @tailwindcss/cli -i templates/input.css -o assets/css/main.css --minify",
    "test": "npx playwright test --config playwright/playwright.config.ts",
    "test:ui": "npx playwright test --config playwright/playwright.config.ts --ui"
  },
  "devDependencies": {
    "daisyui": "5.5.19",
    "@tailwindcss/cli": "4.2.2",
    "@playwright/test": "1.59.1"
  }
}
