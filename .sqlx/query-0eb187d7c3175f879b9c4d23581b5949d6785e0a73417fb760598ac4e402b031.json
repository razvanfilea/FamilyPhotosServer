{
  "db_name": "SQLite",
  "query": "SELECT DISTINCT p.* FROM photos p\n            LEFT JOIN folder_permissions fp ON fp.grantee_id = $1\n                AND fp.owner_id = p.user_id\n                AND fp.folder_name = p.folder\n                AND (fp.expires_at IS NULL OR fp.expires_at > datetime('now'))\n            WHERE p.user_id IS NULL\n                OR p.user_id = $1\n                OR fp.id IS NOT NULL\n            ORDER BY p.created_at DESC",
